---
Language: Cpp
BasedOnStyle: LLVM

# 4-space indentation (Boost/nous convention; LLVM default is 2)
IndentWidth: 4
ContinuationIndentWidth: 4
TabWidth: 4
UseTab: Never

# Column limit — generous for template-heavy C++20
ColumnLimit: 100

# Pointer/reference on the type side: 'T& x', 'T* x'
PointerAlignment: Left
ReferenceAlignment: Left

# Namespace indentation: outer stays at col 0; inner namespaces indented
NamespaceIndentation: Inner

# Short functions allowed on one line only inside class/struct bodies
AllowShortFunctionsOnASingleLine: InlineOnly
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: Never

# Consecutive-member / variable alignment within a block
AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
  AlignFunctionPointers: false
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false

# Trailing comments: align within a block
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 0

# Initialiser-list braces: no spaces inside {}
Cpp11BracedListStyle: true

# Includes: sort within existing groups; don't merge/reorder groups
SortIncludes: CaseSensitive
IncludeBlocks: Preserve
